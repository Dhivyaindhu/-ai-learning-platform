{% comment %}templates/ai_engine/module_quiz_result.html{% endcomment %}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Quiz Results — {{ module.module_title }}</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet"/>
  <style>
    :root { --bg:#0d1117; --surface:#161b22; --border:#30363d; --accent:#58a6ff; --success:#3fb950; --danger:#f85149; --text:#e6edf3; --muted:#8b949e; }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; padding: 2rem 1rem; }
    .container { max-width: 780px; margin: 0 auto; }

    /* ── Score header ── */
    .score-header { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; padding: 2rem; text-align: center; margin-bottom: 1.5rem; }
    .score-circle { display: inline-flex; align-items: center; justify-content: center; width: 110px; height: 110px; border-radius: 50%; border: 4px solid var(--border); font-size: 2rem; font-weight: 700; margin-bottom: 1rem; }
    .score-circle.passed { border-color: var(--success); color: var(--success); }
    .score-circle.failed { border-color: var(--danger); color: var(--danger); }
    .score-header h1 { font-size: 1.5rem; margin-bottom: .4rem; }
    .score-header p { color: var(--muted); font-size: .92rem; }
    .badge { display: inline-block; padding: .35rem .85rem; border-radius: 20px; font-size: .8rem; font-weight: 600; margin-top: .75rem; }
    .badge.passed { background: rgba(63,185,80,.15); color: var(--success); }
    .badge.failed { background: rgba(248,81,73,.15); color: var(--danger); }

    /* ── Results list ── */
    .section-title { font-size: 1.1rem; font-weight: 600; margin-bottom: 1rem; }
    .question-card { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 1.25rem; margin-bottom: .85rem; }
    .question-card.correct { border-left: 3px solid var(--success); }
    .question-card.wrong   { border-left: 3px solid var(--danger); }
    .question-text { font-size: .95rem; font-weight: 500; margin-bottom: .9rem; }
    .options { display: flex; flex-direction: column; gap: .45rem; }
    .option { display: flex; align-items: center; gap: .6rem; font-size: .85rem; padding: .5rem .75rem; border-radius: 8px; background: var(--bg); border: 1px solid var(--border); }
    .option.correct-ans { background: rgba(63,185,80,.1); border-color: var(--success); color: var(--success); font-weight: 600; }
    .option.user-wrong  { background: rgba(248,81,73,.1); border-color: var(--danger); color: var(--danger); }
    .option-icon { font-size: .85rem; flex-shrink: 0; }
    .result-label { font-size: .75rem; font-weight: 600; float: right; padding: .2rem .6rem; border-radius: 5px; }
    .result-label.correct { background: rgba(63,185,80,.15); color: var(--success); }
    .result-label.wrong   { background: rgba(248,81,73,.15); color: var(--danger); }

    /* ── Actions ── */
    .actions { display: flex; gap: .75rem; margin-top: 1.5rem; flex-wrap: wrap; }
    .btn { display: inline-block; padding: .6rem 1.2rem; border-radius: 8px; font-weight: 600; font-size: .88rem; text-decoration: none; }
    .btn-primary { background: var(--accent); color: #0d1117; }
    .btn-primary:hover { opacity: .88; }
    .btn-secondary { background: var(--surface); color: var(--text); border: 1px solid var(--border); }
    .btn-secondary:hover { border-color: var(--accent); }
  </style>
</head>
<body>
<div class="container">

  <!-- Score Summary -->
  <div class="score-header">
    <div class="score-circle {% if passed %}passed{% else %}failed{% endif %}">
      {{ pct }}%
    </div>
    <h1>{{ module.module_title }}</h1>
    <p>You answered {{ score }} out of {{ total }} questions correctly.</p>
    <span class="badge {% if passed %}passed{% else %}failed{% endif %}">
      {% if passed %}✓ Passed — Module Marked Complete{% else %}✗ Not Passed — Review &amp; Retry{% endif %}
    </span>
  </div>

  <!-- Question Breakdown -->
  <div class="section-title">Question Breakdown</div>

  {% for r in results %}
  <div class="question-card {% if r.is_correct %}correct{% else %}wrong{% endif %}">
    <div class="question-text">
      Q{{ forloop.counter }}. {{ r.question }}
      <span class="result-label {% if r.is_correct %}correct{% else %}wrong{% endif %}">
        {% if r.is_correct %}Correct{% else %}Incorrect{% endif %}
      </span>
    </div>
    <div class="options">
      {% for letter, text in r.options.items %}
        <div class="option
          {% if letter == r.correct %}correct-ans
          {% elif letter == r.user_answer and not r.is_correct %}user-wrong
          {% endif %}">
          <span class="option-icon">
            {% if letter == r.correct %}✓
            {% elif letter == r.user_answer and not r.is_correct %}✗
            {% else %}·
            {% endif %}
          </span>
          <span><strong>{{ letter }}.</strong> {{ text }}</span>
        </div>
      {% endfor %}
    </div>
  </div>
  {% endfor %}

  <!-- Actions -->
  <div class="actions">
    <a href="{% url 'ai_engine:module_learn' module.id %}" class="btn btn-primary">Back to Module →</a>
    {% if not passed %}
      <a href="{% url 'ai_engine:module_quiz' module.id %}" class="btn btn-secondary">Retry Quiz</a>
    {% endif %}
    <a href="{% url 'ai_engine:course_detail' module.course.id %}" class="btn btn-secondary">Course Overview</a>
  </div>

</div>
</body>
</html>